<footer class="footer">
    <div class="container">
        <div class="footer-top-divider" aria-hidden="true"></div>
        <div class="footer-grid">
            <div class="footer-brand">
                <picture>
                    <source srcset="/brand/logo.webp" type="image/webp">
                    <img src="/brand/logo.png" alt="Cardinal Six Cyber" class="footer-logo" width="640" height="640" loading="lazy">
                </picture>
                <p>Practitioner-led cybersecurity consulting for defense contractors, federal agencies, and critical infrastructure. Built on mission experience.</p>
            </div>
            <div class="footer-col">
                <p class="footer-heading">Services</p>
                <ul>
                    <li><a href="/#services">CMMC Readiness</a></li>
                    <li><a href="/#services">RMF Authorization</a></li>
                    <li><a href="/#services">STIG Compliance</a></li>
                    <li><a href="/#services">Vulnerability Mgmt</a></li>
                    <li><a href="/#services">Risk Management</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <p class="footer-heading">Company</p>
                <ul>
                    <li><a href="/#why-c6">About C6</a></li>
                    <li><a href="/#frameworks">Frameworks</a></li>
                    <li><a href="/news">Cyber News</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <p class="footer-heading">Resources</p>
                <ul>
                    <li><a href="/cmmc">CMMC Practices</a></li>
                    <li><a href="/nist-800-171">NIST 800-171</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <p class="footer-heading">Contact</p>
                <div class="footer-contact-item">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
                    <a href="mailto:info@cardinalsixcyber.com">info@cardinalsixcyber.com</a>
                </div>
                <div class="footer-contact-item">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span>Chesapeake, VA</span>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="footer-copy">
                &copy; {new Date().getFullYear()} Cardinal Six Cyber LLC. All rights reserved.<br>
                <span style="font-size: 0.7rem; color: var(--c6-text-dim);">A Begarek Enterprises LLC company.</span>
            </div>
            <div class="footer-legal">
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
            </div>
        </div>
    </div>
</footer>
