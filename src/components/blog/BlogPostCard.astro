---
import BlogLaneBadge from './BlogLaneBadge.astro';

interface Props {
  href: string;
  title: string;
  description?: string;
  lane?: string;
  publishDate?: string | Date;
  topics?: string[];
  featured?: boolean;
  class?: string;
}

const {
  href,
  title,
  description,
  lane,
  publishDate,
  topics = [],
  featured = false,
  class: className = '',
} = Astro.props as Props;

function formatDate(value?: string | Date) {
  if (!value) return '';

  const date = value instanceof Date ? value : new Date(value);
  if (Number.isNaN(date.getTime())) return typeof value === 'string' ? value : '';

  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date);
}

function getDateTimeValue(value?: string | Date) {
  if (!value) return undefined;

  if (value instanceof Date) {
    return value.toISOString();
  }

  if (/^\d{4}-\d{2}-\d{2}$/.test(value)) {
    return value;
  }

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;

  return date.toISOString();
}

const formattedDate = formatDate(publishDate);
const datetimeValue = getDateTimeValue(publishDate);
---

<article
  class:list={['blog-post-card', featured && 'is-featured', className].filter(Boolean)}
  data-lane={lane?.trim().toLowerCase() || ''}
  data-featured={featured ? 'true' : 'false'}
  data-topics={topics.map((topic) => topic.trim().toLowerCase()).filter(Boolean).join('|')}
>
  <a class="blog-post-card-link" href={href}>
    <div class="blog-post-card-meta">
      <BlogLaneBadge lane={lane} />
      {formattedDate ? <time class="blog-post-card-date" datetime={datetimeValue}>{formattedDate}</time> : null}
      {featured ? <span class="blog-post-card-featured">Featured</span> : null}
    </div>

    <h3 class="blog-post-card-title">{title}</h3>

    {description ? <p class="blog-post-card-description">{description}</p> : null}

    {topics.length ? (
      <ul class="blog-post-card-topics" aria-label="Topics">
        {topics.map((topic) => <li>{topic}</li>)}
      </ul>
    ) : null}
  </a>
</article>

<style>
  .blog-post-card {
    background: var(--c6-black-elevated);
    border: 1px solid var(--c6-border);
    border-radius: 0;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .blog-post-card.is-featured {
    border-top: 2px solid transparent;
    border-image: var(--c6-gradient-accent) 1;
    border-image-slice: 1 0 0 0;
  }

  .blog-post-card-link {
    display: block;
    padding: var(--space-6);
    color: inherit;
    text-decoration: none;
  }

  .blog-post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .blog-post-card:focus-within {
    border-color: var(--c6-red-text);
  }

  .blog-post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .blog-post-card-date,
  .blog-post-card-featured {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--c6-text-dim);
    text-transform: uppercase;
  }

  .blog-post-card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.3;
    color: var(--c6-text-primary);
    margin: 0 0 var(--space-3);
  }

  .blog-post-card-description {
    margin: 0 0 var(--space-4);
    color: var(--c6-text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .blog-post-card-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-post-card-topics li {
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--c6-border);
    border-radius: var(--radius-sm);
    color: var(--c6-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .blog-post-card-link {
      padding: var(--space-5);
    }
  }
</style>
