---
import ComplianceCTA from './ComplianceCTA.astro';

interface Props {
    id: string;
    displayId: string;
    title: string;
    family: string;
    familyCode: string;
    description: string;
    supplementalGuidance: string | null;
    relatedControls: { id: string; displayId: string; url: string }[];
    cmmcRefs: { id: string; displayId: string; url: string }[];
    nist171Refs: { id: string; displayId: string; url: string }[];
    notes: string | null;
    sameFamilyControls: { id: string; displayId: string; title: string; url: string }[];
}

const {
    id,
    displayId,
    title,
    family,
    familyCode,
    description,
    supplementalGuidance,
    relatedControls,
    cmmcRefs,
    nist171Refs,
    notes,
    sameFamilyControls,
} = Astro.props;

const groupIndexUrl = `/nist-800-53#${familyCode.toLowerCase()}`;
const familyUrl = `/nist-800-53#${familyCode.toLowerCase()}`;
---

<article class="detail-page">
    <!-- Section 1: Breadcrumb bar -->
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li><a href="/" class="breadcrumb-link">Home</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href="/nist-800-53" class="breadcrumb-link">NIST 800-53</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href={familyUrl} class="breadcrumb-link">{family}</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li class="breadcrumb-current" aria-current="page">{displayId}</li>
        </ol>
    </nav>

    <!-- Section 2: Header block -->
    <header class="detail-header">
        <p class="eyebrow">NIST 800-53 REV 5 &bull; {family.toUpperCase()}</p>
        <h1 class="detail-title">{displayId}<span class="title-sep"> &mdash; </span>{title}</h1>
        <div class="divider"></div>
        <p class="detail-description">{description}</p>
    </header>

    <!-- Section 3: Cross-reference cards (3-column grid) -->
    <section class="crossref-section" aria-label="Cross-references">
        <div class="crossref-grid">
            <div class="crossref-card">
                <h3 class="crossref-label">CMMC Practice Mapping</h3>
                {cmmcRefs.length > 0 ? (
                    <ul class="crossref-items">
                        {cmmcRefs.map((item) => (
                            <li>
                                <a href={item.url} class="crossref-link">{item.displayId}</a>
                            </li>
                        ))}
                    </ul>
                ) : (
                    <p class="crossref-empty">No direct CMMC mapping</p>
                )}
            </div>
            <div class="crossref-card">
                <h3 class="crossref-label">NIST 800-171 Mapping</h3>
                {nist171Refs.length > 0 ? (
                    <ul class="crossref-items">
                        {nist171Refs.map((item) => (
                            <li>
                                <a href={item.url} class="crossref-link">{item.displayId}</a>
                            </li>
                        ))}
                    </ul>
                ) : (
                    <p class="crossref-empty">No direct NIST 800-171 mapping</p>
                )}
            </div>
            <div class="crossref-card">
                <h3 class="crossref-label">Related Controls</h3>
                {relatedControls.length > 0 ? (
                    <ul class="crossref-items">
                        {relatedControls.map((item) => (
                            <li>
                                <a href={item.url} class="crossref-link">{item.displayId}</a>
                            </li>
                        ))}
                    </ul>
                ) : (
                    <p class="crossref-empty">No related controls listed</p>
                )}
            </div>
        </div>
    </section>

    <!-- Section 4: Supplemental Guidance (hidden when null/empty) -->
    {supplementalGuidance && (
        <section class="guidance-section" aria-label="Supplemental Guidance">
            <div class="guidance-card">
                <h2 class="guidance-label">Supplemental Guidance</h2>
                <p class="guidance-text">{supplementalGuidance}</p>
            </div>
        </section>
    )}

    <!-- Section 5: Practitioner Notes -->
    <section class="notes-section" aria-label="Practitioner Notes">
        {notes ? (
            <div class="notes-card">
                <h2 class="notes-label">Practitioner Notes</h2>
                <div class="notes-content" set:html={notes} />
            </div>
        ) : (
            <div class="notes-card notes-card--empty">
                <h2 class="notes-label">Practitioner Notes</h2>
                <p class="notes-placeholder">Practitioner commentary coming soon.</p>
            </div>
        )}
    </section>

    <!-- Section 6: CTA -->
    <section class="cta-section" aria-label="Call to action">
        <ComplianceCTA level={2} groupName={family} groupIndexUrl={groupIndexUrl} />
    </section>

    <!-- Section 7: Same-Family Controls -->
    {sameFamilyControls.length > 0 && (
        <section class="related-section" aria-label={`Other ${family} controls`}>
            <h2 class="related-heading">More {family} Controls</h2>
            <div class="divider divider--centered"></div>
            <div class="related-grid">
                {sameFamilyControls.slice(0, 4).map((item) => (
                    <a href={item.url} class="related-card">
                        <span class="related-id">{item.displayId}</span>
                        <span class="related-title">{item.title}</span>
                    </a>
                ))}
            </div>
        </section>
    )}
</article>

<style>
    /* === Detail page container === */
    .detail-page {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    /* === Section 1: Breadcrumb bar === */
    .breadcrumb-bar {
        margin-bottom: var(--space-10);
        padding: var(--space-3) var(--space-4);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
    }

    .breadcrumb-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
        list-style: none;
        margin: 0;
        padding: 0;
        font-family: var(--font-body);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .breadcrumb-link {
        color: var(--c6-text-muted);
        text-decoration: none;
        transition: color 250ms;
    }

    .breadcrumb-link:hover,
    .breadcrumb-link:focus-visible {
        color: var(--c6-red-text);
    }

    .breadcrumb-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
        border-radius: 2px;
    }

    .breadcrumb-sep {
        color: var(--c6-text-dim);
        user-select: none;
    }

    .breadcrumb-current {
        color: var(--c6-text-secondary);
        font-weight: 500;
    }

    /* === Section 2: Header block === */
    .detail-header {
        margin-bottom: var(--space-12);
    }

    .eyebrow {
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--c6-red-text);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.4;
    }

    .detail-title {
        font-family: var(--font-display);
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.15;
    }

    .title-sep {
        color: var(--c6-text-dim);
        font-weight: 400;
    }

    .divider {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0 0 var(--space-6) 0;
    }

    .detail-description {
        font-family: var(--font-body);
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--c6-text-body);
        margin: 0;
        max-width: 780px;
    }

    /* === Section 3: Cross-reference cards (3-column) === */
    .crossref-section {
        margin-bottom: var(--space-12);
    }

    .crossref-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: var(--space-6);
    }

    .crossref-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
        transition: border-color 250ms;
    }

    .crossref-card:hover {
        border-color: var(--c6-border-accent);
    }

    .crossref-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .crossref-items {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .crossref-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--c6-text-secondary);
        text-decoration: none;
        padding: var(--space-1) var(--space-3);
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
        transition: color 250ms, border-color 250ms;
    }

    .crossref-link:hover,
    .crossref-link:focus-visible {
        color: var(--c6-red-text);
        border-color: var(--c6-border-accent);
    }

    .crossref-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .crossref-empty {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--c6-text-muted);
        margin: 0;
        font-style: italic;
    }

    /* === Section 4: Supplemental Guidance === */
    .guidance-section {
        margin-bottom: var(--space-12);
    }

    .guidance-card {
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-6) var(--space-6) var(--space-6) var(--space-8);
        box-shadow: var(--shadow-card);
    }

    .guidance-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .guidance-text {
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--c6-text-body);
        margin: 0;
    }

    /* === Section 5: Practitioner Notes === */
    .notes-section {
        margin-bottom: var(--space-12);
    }

    .notes-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-left: 3px solid var(--c6-gold);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
    }

    .notes-card--empty {
        border-left-color: var(--c6-text-dim);
    }

    .notes-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .notes-content {
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--c6-text-body);
    }

    .notes-content :global(p) {
        margin: 0 0 var(--space-4) 0;
    }

    .notes-content :global(p:last-child) {
        margin-bottom: 0;
    }

    .notes-content :global(ul),
    .notes-content :global(ol) {
        margin: 0 0 var(--space-4) var(--space-6);
        padding: 0;
    }

    .notes-content :global(li) {
        margin-bottom: var(--space-2);
    }

    .notes-placeholder {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--c6-text-muted);
        margin: 0;
        font-style: italic;
    }

    /* === Section 6: CTA === */
    .cta-section {
        margin-bottom: var(--space-12);
    }

    /* === Section 7: Same-Family Controls === */
    .related-section {
        margin-bottom: var(--space-12);
    }

    .related-heading {
        font-family: var(--font-display);
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-4) 0;
        text-align: center;
        line-height: 1.2;
    }

    .divider--centered {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0 auto var(--space-8);
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
    }

    .related-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-4) var(--space-6);
        text-decoration: none;
        box-shadow: var(--shadow-card);
        transition: border-color 250ms, transform 250ms, box-shadow 250ms;
    }

    .related-card:hover {
        border-color: var(--c6-border-accent);
        transform: translateY(-2px);
        box-shadow: var(--shadow-card-hover);
    }

    .related-card:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .related-id {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--c6-gold);
        letter-spacing: 0.04em;
    }

    .related-title {
        font-family: var(--font-body);
        font-size: 0.88rem;
        line-height: 1.5;
        color: var(--c6-text-body);
    }

    /* === Responsive === */
    @media (max-width: 640px) {
        .detail-page {
            padding: var(--space-6) var(--space-4);
        }

        .crossref-grid {
            grid-template-columns: 1fr;
        }

        .detail-title {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
        }

        .eyebrow {
            font-size: 0.78rem;
            letter-spacing: 0.15em;
        }

        .related-grid {
            grid-template-columns: 1fr;
        }

        .guidance-card {
            padding-left: var(--space-6);
        }
    }
</style>
