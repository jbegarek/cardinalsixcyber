---
interface Props {
    framework: 'cmmc' | 'nist-800-171';
    id: string;
    displayId: string;
    title: string;
    groupName: string;
    groupCode: string;
    level: number;
    description: string;
    assessmentObjectives: string[];
    crossRefs: { label: string; items: { id: string; displayId: string; url: string }[] }[];
    nist80053: string[];
    notes: string | null;
    relatedItems: { id: string; displayId: string; title: string; url: string }[];
}

const {
    framework,
    id,
    displayId,
    title,
    groupName,
    groupCode,
    level,
    description,
    assessmentObjectives,
    crossRefs,
    nist80053,
    notes,
    relatedItems,
} = Astro.props;

const isCmmc = framework === 'cmmc';
const frameworkLabel = isCmmc ? 'CMMC 2.0' : 'NIST 800-171';
const frameworkUrl = isCmmc ? '/cmmc' : '/nist-800-171';
const groupUrl = isCmmc
    ? `/cmmc#${groupCode.toLowerCase()}`
    : `/nist-800-171#${groupCode}`;

const eyebrowParts = [
    frameworkLabel,
    `LEVEL ${level}`,
    groupName.toUpperCase(),
];
---

<article class="detail-page">
    <!-- Section 1: Breadcrumb bar -->
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li><a href="/" class="breadcrumb-link">Home</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href={frameworkUrl} class="breadcrumb-link">{frameworkLabel}</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href={groupUrl} class="breadcrumb-link">{groupName}</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li class="breadcrumb-current" aria-current="page">{displayId}</li>
        </ol>
    </nav>

    <!-- Section 2: Header block -->
    <header class="detail-header">
        <p class="eyebrow">{eyebrowParts.join(' \u2022 ')}</p>
        <h1 class="detail-title">{displayId}<span class="title-sep"> &mdash; </span>{title}</h1>
        <div class="divider"></div>
        <p class="detail-description">{description}</p>
    </header>

    <!-- Section 3: Cross-reference cards -->
    <section class="crossref-section" aria-label="Cross-references">
        <div class="crossref-grid">
            <div class="crossref-column">
                {crossRefs.map((ref) => (
                    <div class="crossref-card">
                        <h3 class="crossref-label">{ref.label}</h3>
                        <ul class="crossref-items">
                            {ref.items.map((item) => (
                                <li>
                                    <a href={item.url} class="crossref-link">{item.displayId}</a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
            <div class="crossref-column">
                <div class="crossref-card">
                    <h3 class="crossref-label">NIST 800-53 Controls</h3>
                    <div class="badge-list">
                        {nist80053.map((ctrl) => (
                            <span class="badge">{ctrl}</span>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TODO: Section 4 — Assessment Objectives -->
    <!-- TODO: Section 5 — Examiner Notes / Discussion -->
    <!-- TODO: Section 6 — Related Practices -->
    <!-- TODO: Section 7 — CTA (ComplianceCTA component) -->
</article>

<style>
    /* === Detail page container === */
    .detail-page {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    /* === Section 1: Breadcrumb bar === */
    .breadcrumb-bar {
        margin-bottom: var(--space-10);
        padding: var(--space-3) var(--space-4);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
    }

    .breadcrumb-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
        list-style: none;
        margin: 0;
        padding: 0;
        font-family: var(--font-body);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .breadcrumb-link {
        color: var(--c6-text-muted);
        text-decoration: none;
        transition: color 250ms;
    }

    .breadcrumb-link:hover,
    .breadcrumb-link:focus-visible {
        color: var(--c6-red-text);
    }

    .breadcrumb-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
        border-radius: 2px;
    }

    .breadcrumb-sep {
        color: var(--c6-text-dim);
        user-select: none;
    }

    .breadcrumb-current {
        color: var(--c6-text-secondary);
        font-weight: 500;
    }

    /* === Section 2: Header block === */
    .detail-header {
        margin-bottom: var(--space-12);
    }

    .eyebrow {
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--c6-red-text);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.4;
    }

    .detail-title {
        font-family: var(--font-display);
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.15;
    }

    .title-sep {
        color: var(--c6-text-dim);
        font-weight: 400;
    }

    .divider {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0 0 var(--space-6) 0;
    }

    .detail-description {
        font-family: var(--font-body);
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--c6-text-body);
        margin: 0;
        max-width: 780px;
    }

    /* === Section 3: Cross-reference cards === */
    .crossref-section {
        margin-bottom: var(--space-12);
    }

    .crossref-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
    }

    .crossref-column {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .crossref-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
        transition: border-color 250ms;
    }

    .crossref-card:hover {
        border-color: var(--c6-border-accent);
    }

    .crossref-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .crossref-items {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .crossref-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--c6-text-secondary);
        text-decoration: none;
        padding: var(--space-1) var(--space-3);
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
        transition: color 250ms, border-color 250ms;
    }

    .crossref-link:hover,
    .crossref-link:focus-visible {
        color: var(--c6-red-text);
        border-color: var(--c6-border-accent);
    }

    .crossref-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .badge-list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .badge {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--c6-text-secondary);
        padding: var(--space-1) var(--space-3);
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
        white-space: nowrap;
    }

    /* === Responsive === */
    @media (max-width: 640px) {
        .detail-page {
            padding: var(--space-6) var(--space-4);
        }

        .crossref-grid {
            grid-template-columns: 1fr;
        }

        .detail-title {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
        }

        .eyebrow {
            font-size: 0.78rem;
            letter-spacing: 0.15em;
        }
    }
</style>
