---
import ComplianceCTA from './ComplianceCTA.astro';
import nist171Data from '../../data/nist-800-171.json';

interface Props {
    framework: 'cmmc' | 'nist-800-171';
    id: string;
    displayId: string;
    title: string;
    groupName: string;
    groupCode: string;
    level: number;
    description: string;
    assessmentObjectives: string[];
    crossRefs: { label: string; items: { id: string; displayId: string; url: string }[] }[];
    nist80053: string[];
    notes: string | null;
    relatedItems: { id: string; displayId: string; title: string; url: string }[];
}

const {
    framework,
    id,
    displayId,
    title,
    groupName,
    groupCode,
    level,
    description,
    assessmentObjectives,
    crossRefs,
    nist80053,
    notes,
    relatedItems,
} = Astro.props;

const isCmmc = framework === 'cmmc';
const groupIndexUrl = isCmmc
    ? `/cmmc#${groupCode.toLowerCase()}`
    : `/nist-800-171#${groupCode}`;
const frameworkLabel = isCmmc ? 'CMMC 2.0' : 'NIST 800-171';
const frameworkUrl = isCmmc ? '/cmmc' : '/nist-800-171';
const groupUrl = isCmmc
    ? `/cmmc#${groupCode.toLowerCase()}`
    : `/nist-800-171#${groupCode}`;

const eyebrowParts = [
    frameworkLabel,
    `LEVEL ${level}`,
    groupName.toUpperCase(),
];

const nist171Ids = new Set(
    (nist171Data as { requirements: { id: string }[] }).requirements.map((r) => r.id)
);

function displayIdToRouteId(displayId: string): string {
    const normalized = displayId
        .split('.')
        .map((part) => String(parseInt(part, 10)))
        .join('.');
    return normalized.replaceAll('.', '-');
}

function controlDisplayIdToRouteId(controlDisplayId: string): string {
    return controlDisplayId
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
}

function sanitizeInlineArtifacts(text: string): string {
    return text.replace(/\{\{\s*insert:\s*param,\s*[^}]+\}\}/g, 'organization-defined parameter');
}

function normalizeCprtRefs(html: string): string {
    const cprtRef =
        /\[([^\]]*)\]\(#\/cprt\/framework\/version\/SP_800_171_3_0_0\/home\?element=([0-9]{2}\.[0-9]{2}\.[0-9]{2})\)\s*([0-9]{2}\.[0-9]{2}\.[0-9]{2})?/g;

    const cprtNormalized = html.replace(cprtRef, (_match, linkText, element, trailingRef) => {
        const label = (trailingRef || linkText || element).trim();
        const targetId = displayIdToRouteId(element);
        if (nist171Ids.has(targetId)) {
            return `<a href="/nist-800-171/${targetId}">${label}</a>`;
        }
        return label;
    });

    return sanitizeInlineArtifacts(cprtNormalized);
}

const normalizedDescription = normalizeCprtRefs(description);
const normalizedAssessmentObjectives = assessmentObjectives.map(normalizeCprtRefs);
const normalizedNotes = notes ? normalizeCprtRefs(notes) : null;
---

<article class="detail-page">
    <!-- Section 1: Breadcrumb bar -->
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li><a href="/" class="breadcrumb-link">Home</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href={frameworkUrl} class="breadcrumb-link">{frameworkLabel}</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href={groupUrl} class="breadcrumb-link">{groupName}</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li class="breadcrumb-current" aria-current="page">{displayId}</li>
        </ol>
    </nav>

    <!-- Section 2: Header block -->
    <header class="detail-header">
        <p class="eyebrow">{eyebrowParts.join(' \u2022 ')}</p>
        <h1 class="detail-title">{displayId}<span class="title-sep"> &mdash; </span>{title}</h1>
        <div class="divider"></div>
        <p class="detail-description" set:html={normalizedDescription} />
    </header>

    <!-- Section 3: Cross-reference cards -->
    <section class="crossref-section" aria-label="Cross-references">
        <div class="crossref-grid">
            <div class="crossref-column">
                {crossRefs.map((ref) => (
                    <div class="crossref-card">
                        <h3 class="crossref-label">{ref.label}</h3>
                        <ul class="crossref-items">
                            {ref.items.map((item) => (
                                <li>
                                    <a href={item.url} class="crossref-link">{item.displayId}</a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
            <div class="crossref-column">
                <div class="crossref-card">
                    <h3 class="crossref-label">NIST 800-53 Controls</h3>
                    <div class="badge-list">
                        {nist80053.map((ctrl) => (
                            <a href={`/nist-800-53/${controlDisplayIdToRouteId(ctrl)}`} class="badge badge-link">{ctrl}</a>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 4: Assessment Objectives -->
    <section class="objectives-section" aria-label="Assessment Objectives">
        <div class="objectives-card">
            <h2 class="objectives-label">Assessment Objectives</h2>
            {assessmentObjectives.length > 0 ? (
                <ul class="objectives-list">
                    {normalizedAssessmentObjectives.map((obj) => (
                        <li class="objective-item">
                            <svg class="objective-check" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20">
                                <rect x="1" y="1" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.5" />
                                <path d="M6 10.5l2.5 2.5 5.5-5.5" stroke="var(--c6-gold)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <span class="objective-text" set:html={obj} />
                        </li>
                    ))}
                </ul>
            ) : (
                <p class="objectives-empty">Assessment objectives not available for this requirement.</p>
            )}
        </div>
    </section>

    <!-- Section 5: Practitioner Notes -->
    <section class="notes-section" aria-label="Practitioner Notes">
        {normalizedNotes ? (
            <div class="notes-card">
                <h2 class="notes-label">Practitioner Notes</h2>
                <div class="notes-content" set:html={normalizedNotes} />
            </div>
        ) : (
            <div class="notes-card notes-card--empty">
                <h2 class="notes-label">Practitioner Notes</h2>
                <p class="notes-placeholder">Practitioner commentary coming soon.</p>
            </div>
        )}
    </section>

    <!-- Section 6: CTA -->
    <section class="cta-section" aria-label="Call to action">
        <ComplianceCTA level={level} groupName={groupName} groupIndexUrl={groupIndexUrl} />
    </section>

    <!-- Section 7: Related Items -->
    {relatedItems.length > 0 && (
        <section class="related-section" aria-label={`Related ${frameworkLabel} requirements`}>
            <h2 class="related-heading">Related {frameworkLabel} {isCmmc ? 'Practices' : 'Requirements'}</h2>
            <div class="divider divider--centered"></div>
            <div class="related-grid">
                {relatedItems.slice(0, 4).map((item) => (
                    <a href={item.url} class="related-card">
                        <span class="related-id">{item.displayId}</span>
                        <span class="related-title">{item.title}</span>
                    </a>
                ))}
            </div>
        </section>
    )}
</article>

<style>
    /* === Detail page container === */
    .detail-page {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    /* === Section 1: Breadcrumb bar === */
    .breadcrumb-bar {
        margin-bottom: var(--space-10);
        padding: var(--space-3) var(--space-4);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
    }

    .breadcrumb-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
        list-style: none;
        margin: 0;
        padding: 0;
        font-family: var(--font-body);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .breadcrumb-link {
        color: var(--c6-text-muted);
        text-decoration: none;
        transition: color 250ms;
    }

    .breadcrumb-link:hover,
    .breadcrumb-link:focus-visible {
        color: var(--c6-red-text);
    }

    .breadcrumb-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
        border-radius: 2px;
    }

    .breadcrumb-sep {
        color: var(--c6-text-dim);
        user-select: none;
    }

    .breadcrumb-current {
        color: var(--c6-text-secondary);
        font-weight: 500;
    }

    /* === Section 2: Header block === */
    .detail-header {
        margin-bottom: var(--space-12);
    }

    .eyebrow {
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--c6-red-text);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.4;
    }

    .detail-title {
        font-family: var(--font-display);
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.15;
    }

    .title-sep {
        color: var(--c6-text-dim);
        font-weight: 400;
    }

    .divider {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0 0 var(--space-6) 0;
    }

    .detail-description {
        font-family: var(--font-body);
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--c6-text-body);
        margin: 0;
        max-width: 780px;
    }

    /* === Section 3: Cross-reference cards === */
    .crossref-section {
        margin-bottom: var(--space-12);
    }

    .crossref-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
    }

    .crossref-column {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .crossref-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
        transition: border-color 250ms;
    }

    .crossref-card:hover {
        border-color: var(--c6-border-accent);
    }

    .crossref-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .crossref-items {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .crossref-link {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--c6-text-secondary);
        text-decoration: none;
        padding: var(--space-1) var(--space-3);
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
        transition: color 250ms, border-color 250ms;
    }

    .crossref-link:hover,
    .crossref-link:focus-visible {
        color: var(--c6-red-text);
        border-color: var(--c6-border-accent);
    }

    .crossref-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .badge-list {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .badge {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--c6-text-secondary);
        padding: var(--space-1) var(--space-3);
        background: var(--c6-black-surface);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
        white-space: nowrap;
    }
    .badge-link {
        text-decoration: none;
        transition: border-color 0.2s ease, color 0.2s ease;
    }
    .badge-link:hover {
        color: var(--c6-red-text);
        border-color: var(--c6-border-accent);
    }
    .badge-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    /* === Section 4: Assessment Objectives === */
    .objectives-section {
        margin-bottom: var(--space-12);
    }

    .objectives-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
    }

    .objectives-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.3;
    }

    .objectives-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .objective-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
    }

    .objective-check {
        flex-shrink: 0;
        color: var(--c6-border-accent);
        margin-top: 2px;
    }

    .objective-text {
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.65;
        color: var(--c6-text-body);
    }

    .objectives-empty {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--c6-text-muted);
        margin: 0;
        font-style: italic;
    }

    /* === Section 5: Practitioner Notes === */
    .notes-section {
        margin-bottom: var(--space-12);
    }

    .notes-card {
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-left: 3px solid var(--c6-gold);
        border-radius: var(--radius-md);
        padding: var(--space-6);
        box-shadow: var(--shadow-card);
    }

    .notes-card--empty {
        border-left-color: var(--c6-text-dim);
    }

    .notes-label {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .notes-content {
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--c6-text-body);
    }

    .notes-content :global(p) {
        margin: 0 0 var(--space-4) 0;
    }

    .notes-content :global(p:last-child) {
        margin-bottom: 0;
    }

    .notes-content :global(ul),
    .notes-content :global(ol) {
        margin: 0 0 var(--space-4) var(--space-6);
        padding: 0;
    }

    .notes-content :global(li) {
        margin-bottom: var(--space-2);
    }

    .notes-placeholder {
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--c6-text-muted);
        margin: 0;
        font-style: italic;
    }

    /* === Section 6: CTA === */
    .cta-section {
        margin-bottom: var(--space-12);
    }

    /* === Section 7: Related Items === */
    .related-section {
        margin-bottom: var(--space-12);
    }

    .related-heading {
        font-family: var(--font-display);
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-4) 0;
        text-align: center;
        line-height: 1.2;
    }

    .divider--centered {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0 auto var(--space-8);
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-4);
    }

    .related-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        padding: var(--space-4) var(--space-6);
        text-decoration: none;
        box-shadow: var(--shadow-card);
        transition: border-color 250ms, transform 250ms, box-shadow 250ms;
    }

    .related-card:hover {
        border-color: var(--c6-border-accent);
        transform: translateY(-2px);
        box-shadow: var(--shadow-card-hover);
    }

    .related-card:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .related-id {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--c6-gold);
        letter-spacing: 0.04em;
    }

    .related-title {
        font-family: var(--font-body);
        font-size: 0.88rem;
        line-height: 1.5;
        color: var(--c6-text-body);
    }

    /* === STIG/CMMC constraint badges === */
    :global(.stig-note) {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--c6-black);
        background: var(--c6-gold);
        border-radius: var(--radius-sm);
        padding: 0.1em 0.45em 0.15em;
        margin-left: 0.3em;
        vertical-align: middle;
        white-space: nowrap;
        cursor: help;
        box-shadow: var(--shadow-gold);
        transition: opacity 200ms;
        text-decoration: none;
    }

    :global(.stig-note:hover) {
        opacity: 0.85;
    }

    /* === Responsive === */
    @media (max-width: 640px) {
        .detail-page {
            padding: var(--space-6) var(--space-4);
        }

        .crossref-grid {
            grid-template-columns: 1fr;
        }

        .detail-title {
            font-size: clamp(1.3rem, 5vw, 1.8rem);
        }

        .eyebrow {
            font-size: 0.78rem;
            letter-spacing: 0.15em;
        }

        .related-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
