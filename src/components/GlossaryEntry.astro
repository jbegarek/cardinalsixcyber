---
interface Props {
    term: string;
    definition: string;
    whyItMatters: string;
    relatedResources: { label: string; url: string }[];
    prevTerm: { id: string; term: string } | null;
    nextTerm: { id: string; term: string } | null;
}

const { term, definition, whyItMatters, relatedResources, prevTerm, nextTerm } = Astro.props;
---

<article class="glossary-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
        <ol class="breadcrumb-list">
            <li><a href="/" class="breadcrumb-link">Home</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li><a href="/glossary" class="breadcrumb-link">Glossary</a></li>
            <li class="breadcrumb-sep" aria-hidden="true">&rsaquo;</li>
            <li class="breadcrumb-current" aria-current="page">{term}</li>
        </ol>
    </nav>

    <!-- Term heading -->
    <header class="glossary-header">
        <h1 class="glossary-title">{term}</h1>
        <div class="divider"></div>
    </header>

    <!-- Definition -->
    <section class="glossary-definition" aria-label="Definition">
        <div class="definition-content" set:html={definition} />
    </section>

    <!-- Why It Matters -->
    <section class="glossary-why" aria-label="Why it matters">
        <h2 class="why-heading">Why It Matters</h2>
        <div class="why-content" set:html={whyItMatters} />
    </section>

    <!-- Related Resources -->
    {relatedResources.length > 0 && (
        <section class="glossary-resources" aria-label="Related resources">
            <h2 class="resources-heading">Related Resources</h2>
            <ul class="resources-list">
                {relatedResources.map((resource) => (
                    <li class="resources-item">
                        <a href={resource.url} class="resources-link">{resource.label}</a>
                    </li>
                ))}
            </ul>
        </section>
    )}

    <!-- Prev/Next navigation -->
    {(prevTerm || nextTerm) && (
        <nav class="glossary-nav" aria-label="Glossary navigation">
            <div class="nav-prev">
                {prevTerm && (
                    <a href={`/glossary/${prevTerm.id}`} class="nav-link nav-link--prev">
                        <span class="nav-direction">&larr; Previous Term</span>
                        <span class="nav-term">{prevTerm.term}</span>
                    </a>
                )}
            </div>
            <div class="nav-next">
                {nextTerm && (
                    <a href={`/glossary/${nextTerm.id}`} class="nav-link nav-link--next">
                        <span class="nav-direction">Next Term &rarr;</span>
                        <span class="nav-term">{nextTerm.term}</span>
                    </a>
                )}
            </div>
        </nav>
    )}
</article>

<style>
    /* === Page container === */
    .glossary-page {
        max-width: 800px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    /* === Breadcrumb === */
    .breadcrumb-bar {
        margin-bottom: var(--space-10);
        padding: var(--space-3) var(--space-4);
        background: var(--c6-black-elevated);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-sm);
    }

    .breadcrumb-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
        list-style: none;
        margin: 0;
        padding: 0;
        font-family: var(--font-body);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .breadcrumb-link {
        color: var(--c6-text-muted);
        text-decoration: none;
        transition: color 250ms;
    }

    .breadcrumb-link:hover,
    .breadcrumb-link:focus-visible {
        color: var(--c6-red-text);
    }

    .breadcrumb-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
        border-radius: 2px;
    }

    .breadcrumb-sep {
        color: var(--c6-text-dim);
        user-select: none;
    }

    .breadcrumb-current {
        color: var(--c6-text-secondary);
        font-weight: 500;
    }

    /* === Header === */
    .glossary-header {
        margin-bottom: var(--space-10);
    }

    .glossary-title {
        font-family: var(--font-display);
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--c6-text-primary);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.15;
    }

    .divider {
        width: 80px;
        height: 2px;
        background: var(--c6-red);
        margin: 0;
    }

    /* === Definition === */
    .glossary-definition {
        margin-bottom: var(--space-12);
    }

    .definition-content {
        font-family: var(--font-body);
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--c6-text-body);
    }

    .definition-content :global(p) {
        margin: 0 0 var(--space-4) 0;
    }

    .definition-content :global(p:last-child) {
        margin-bottom: 0;
    }

    .definition-content :global(ul),
    .definition-content :global(ol) {
        margin: 0 0 var(--space-4) var(--space-6);
        padding: 0;
    }

    .definition-content :global(li) {
        margin-bottom: var(--space-2);
    }

    .definition-content :global(a) {
        color: var(--c6-red-text);
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 250ms;
    }

    .definition-content :global(a:hover) {
        color: var(--c6-gold-light);
    }

    /* === Why It Matters === */
    .glossary-why {
        margin-bottom: var(--space-12);
        padding-left: var(--space-6);
        border-left: 3px solid var(--c6-gold);
    }

    .why-heading {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-gold);
        margin: 0 0 var(--space-4) 0;
        line-height: 1.3;
    }

    .why-content {
        font-family: var(--font-body);
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--c6-text-body);
    }

    .why-content :global(p) {
        margin: 0 0 var(--space-4) 0;
    }

    .why-content :global(p:last-child) {
        margin-bottom: 0;
    }

    .why-content :global(a) {
        color: var(--c6-red-text);
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 250ms;
    }

    .why-content :global(a:hover) {
        color: var(--c6-gold-light);
    }

    /* === Related Resources === */
    .glossary-resources {
        margin-bottom: var(--space-12);
    }

    .resources-heading {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--c6-text-secondary);
        margin: 0 0 var(--space-6) 0;
        line-height: 1.3;
    }

    .resources-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .resources-item {
        padding: var(--space-3) 0;
        border-bottom: 1px solid var(--c6-border);
    }

    .resources-item:first-child {
        border-top: 1px solid var(--c6-border);
    }

    .resources-link {
        font-family: var(--font-body);
        font-size: 0.95rem;
        color: var(--c6-red-text);
        text-decoration: none;
        transition: color 250ms;
        line-height: 1.5;
    }

    .resources-link:hover,
    .resources-link:focus-visible {
        color: var(--c6-gold-light);
    }

    .resources-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
        border-radius: 2px;
    }

    /* === Prev/Next Navigation === */
    .glossary-nav {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: var(--space-4);
        padding-top: var(--space-8);
        border-top: 1px solid var(--c6-border);
    }

    .nav-prev,
    .nav-next {
        flex: 1;
        min-width: 0;
    }

    .nav-next {
        text-align: right;
    }

    .nav-link {
        display: inline-flex;
        flex-direction: column;
        gap: var(--space-1);
        text-decoration: none;
        padding: var(--space-3) var(--space-4);
        border: 1px solid var(--c6-border);
        border-radius: var(--radius-md);
        transition: border-color 250ms, transform 250ms;
    }

    .nav-link:hover {
        border-color: var(--c6-border-accent);
        transform: translateY(-1px);
    }

    .nav-link:focus-visible {
        outline: 2px solid var(--c6-red-text);
        outline-offset: 2px;
    }

    .nav-link:active {
        transform: translateY(0);
    }

    .nav-link--next {
        align-items: flex-end;
    }

    .nav-direction {
        font-family: var(--font-body);
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--c6-text-muted);
    }

    .nav-term {
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--c6-red-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
    }

    /* === Responsive === */
    @media (max-width: 640px) {
        .glossary-page {
            padding: var(--space-6) var(--space-4);
        }

        .glossary-title {
            font-size: clamp(1.4rem, 5vw, 1.8rem);
        }

        .glossary-why {
            padding-left: var(--space-4);
        }

        .glossary-nav {
            flex-direction: column;
            gap: var(--space-3);
        }

        .nav-next {
            text-align: left;
        }

        .nav-link--next {
            align-items: flex-start;
        }
    }
</style>
