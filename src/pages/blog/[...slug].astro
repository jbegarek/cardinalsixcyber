---
import { getCollection, getEntry, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const resolvedEntry = await getEntry('blog', Astro.params.slug);

if (!resolvedEntry) {
  throw new Error(`Missing blog entry for slug: ${Astro.params.slug}`);
}

const entry = {
  ...resolvedEntry,
  render: () => render(resolvedEntry),
};
const { Content } = await entry.render();

const canonical = entry.data.canonicalUrl ?? `https://cardinalsixcyber.com/blog/${entry.id}`;

const wordCount = entry.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Compute related posts by topic overlap, excluding the current post
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const currentTopics = new Set((entry.data.topics ?? []).map((t) => t.toLowerCase()));

const scored = allPosts
  .filter((p) => p.id !== entry.id)
  .map((p) => {
    const overlap = (p.data.topics ?? []).filter((t) =>
      currentTopics.has(t.toLowerCase()),
    ).length;
    return { post: p, overlap };
  })
  .filter(({ overlap }) => overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.post.data.publishDate.getTime() - a.post.data.publishDate.getTime())
  .slice(0, 3)
  .map(({ post }) => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    lane: post.data.lane,
    publishDate: post.data.publishDate,
    topics: post.data.topics,
    featured: post.data.featured,
  }));
---

<BlogPostLayout
  title={entry.data.title}
  seoTitle={`${entry.data.title} | Cardinal Six Cyber`}
  description={entry.data.description}
  canonical={canonical}
  lane={entry.data.lane}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  featured={entry.data.featured}
  topics={entry.data.topics}
  citations={entry.data.citations}
  diagrams={entry.data.diagrams}
  heroStyle={entry.data.heroStyle}
  heroImage={entry.data.heroImage}
  relatedPosts={scored}
  readingTime={readingTime}
>
  <Content />
</BlogPostLayout>
