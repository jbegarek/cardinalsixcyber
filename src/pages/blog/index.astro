---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const laneOptions = [
  { label: 'All', value: 'all' },
  { label: 'Practical', value: 'practical' },
  { label: 'Research', value: 'research' },
  { label: 'CMMC Journey', value: 'journey' },
];

const topics = Array.from(
  new Map(
    posts.flatMap((post) => post.data.topics).map((topic) => [topic.trim().toLowerCase(), topic.trim()])
  ).values()
).sort((a, b) => a.localeCompare(b));

const initialFeatured = posts.find((post) => post.data.featured) ?? posts[0] ?? null;
const initialFeed = initialFeatured ? posts.filter((post) => post.id !== initialFeatured.id) : [];

const laneLabel = {
  practical: 'Practical',
  research: 'Research',
  journey: 'CMMC Journey',
};
---

<BaseLayout
  title="Cybersecurity Blog — CMMC, NIST & DFARS Practitioner Writing | C6 Cyber"
  description="Practitioner cybersecurity writing on CMMC 2.0, NIST SP 800-171, DFARS compliance, and defense industrial base risk management. Practical and research lanes, newest first."
  canonical="https://cardinalsixcyber.com/blog"
  ogDescription="Practitioner cybersecurity writing on CMMC 2.0, NIST SP 800-171, DFARS, and defense industrial base risk. New posts weekly."
  navFixed={false}
  activePage="blog"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: 'Blog',
      description: 'Practical and research-driven cybersecurity writing from Cardinal Six Cyber.',
      url: 'https://cardinalsixcyber.com/blog',
      isPartOf: { '@type': 'WebSite', name: 'Cardinal Six Cyber', url: 'https://cardinalsixcyber.com' },
    })} />
  </Fragment>

  <section class="blog-index-hero" aria-labelledby="blog-index-title">
    <div class="container blog-index-hero-inner">
      <span class="eyebrow reveal">Insights</span>
      <h1 id="blog-index-title" class="blog-index-title reveal reveal-delay-1">Blog</h1>
      <div class="divider reveal reveal-delay-2"></div>
      <p class="section-sub blog-index-subtitle reveal reveal-delay-2">
        Newest-first writing from the practical and research lanes, with filters to narrow the feed by topic.
      </p>
    </div>
  </section>

  <section class="blog-index-filters" aria-labelledby="blog-index-filters-title">
    <div class="container">
      <h2 id="blog-index-filters-title" class="sr-only">Blog filters</h2>

      <div class="blog-index-filter-group" role="group" aria-label="Filter by lane">
        {laneOptions.map((option) => (
          <button
            type="button"
            class:list={['blog-index-filter', option.value === 'all' && 'is-active'].filter(Boolean)}
            data-filter-kind="lane"
            data-filter-value={option.value}
            aria-pressed={option.value === 'all' ? 'true' : 'false'}
          >
            {option.label}
          </button>
        ))}
      </div>

      <div class="blog-index-filter-group" role="group" aria-label="Filter by topic">
        <button
          type="button"
          class:list={['blog-index-filter', 'is-active']}
          data-filter-kind="topic"
          data-filter-value="all"
          aria-pressed="true"
        >
          All Topics
        </button>
        {topics.map((topic) => (
          <button
            type="button"
            class="blog-index-filter"
            data-filter-kind="topic"
            data-filter-value={topic.toLowerCase()}
            aria-pressed="false"
          >
            {topic}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="blog-index-feed" aria-label="Blog posts">
    <div class="container">
      <div class="blog-index-state" id="blogIndexState" hidden>
        <h2 class="blog-index-state-title">No posts match these filters</h2>
        <p class="blog-index-state-copy">Try switching the lane or topic filters to surface a different slice of the archive.</p>
      </div>

      <section class="blog-index-featured-wrap" id="featuredWrap">
        <div class="blog-index-section-head">
          <span class="blog-index-kicker">Featured Post</span>
          <h2 class="blog-index-section-title">Highlighted Reading</h2>
        </div>

        {initialFeatured ? (
          <div class="blog-index-featured" id="featuredSlot">
            <BlogPostCard
              href={`/blog/${initialFeatured.id}`}
              title={initialFeatured.data.title}
              description={initialFeatured.data.description}
              lane={laneLabel[initialFeatured.data.lane]}
              publishDate={initialFeatured.data.publishDate}
              topics={initialFeatured.data.topics}
              featured={true}
              class="blog-index-card blog-index-card-featured"
            />
          </div>
        ) : null}
      </section>

      <section class="blog-index-feed-wrap" id="feedWrap" aria-labelledby="blog-index-feed-title">
        <div class="blog-index-section-head">
          <span class="blog-index-kicker">Feed</span>
          <h2 id="blog-index-feed-title" class="blog-index-section-title">More Posts</h2>
        </div>

        <div class="blog-index-grid" id="feedGrid">
          {initialFeed.map((post) => (
            <div
              class="blog-index-card-wrap"
              data-blog-post
              data-lane={post.data.lane}
              data-featured={post.data.featured ? 'true' : 'false'}
              data-topics={post.data.topics.map((topic) => topic.trim().toLowerCase()).join('|')}
            >
              <BlogPostCard
                href={`/blog/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                lane={laneLabel[post.data.lane]}
                publishDate={post.data.publishDate}
                topics={post.data.topics}
                featured={post.data.featured}
                class="blog-index-card"
              />
            </div>
          ))}
        </div>
      </section>
    </div>
  </section>

  <Fragment set:html={`<script src="/js/blog-index.js" defer></${""}script>`} />
</BaseLayout>

<style>
  .blog-index-hero {
    padding: calc(var(--space-32) + var(--space-8)) 0 var(--space-12);
    background: var(--c6-gradient-hero);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .blog-index-hero::before {
    content: '';
    position: absolute;
    inset: auto 50% 0;
    width: 760px;
    height: 420px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(192, 57, 43, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .blog-index-hero-inner {
    position: relative;
    z-index: 1;
  }

  .blog-index-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c6-text-primary);
    margin: var(--space-4) 0 0;
  }

  .blog-index-subtitle {
    max-width: 720px;
  }

  .blog-index-filters {
    position: sticky;
    top: 64px;
    z-index: 100;
    background: rgba(17, 17, 17, 0.94);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c6-border);
    padding: var(--space-4) 0;
  }

  .blog-index-filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .blog-index-filter-group::-webkit-scrollbar {
    display: none;
  }

  .blog-index-filter {
    appearance: none;
    border: 1px solid var(--c6-border);
    background: transparent;
    color: var(--c6-text-muted);
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: var(--space-2) var(--space-4);
    min-height: 44px;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .blog-index-filter:hover {
    border-color: var(--c6-border-accent);
    color: var(--c6-text-secondary);
    transform: translateY(-1px);
  }

  .blog-index-filter:focus-visible {
    outline: 2px solid var(--c6-red-text);
    outline-offset: 2px;
  }

  .blog-index-filter.is-active {
    background: var(--c6-red-gradient);
    border-color: transparent;
    color: var(--c6-text-primary);
  }

  .blog-index-feed {
    position: relative;
    padding: var(--space-12) 0 var(--space-16);
    background: var(--c6-gradient-section);
  }

  .blog-index-feed::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top, rgba(192, 57, 43, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .blog-index-feed .container {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-12);
  }

  .blog-index-section-head {
    margin-bottom: var(--space-6);
  }

  .blog-index-kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c6-red-text);
    margin-bottom: var(--space-2);
  }

  .blog-index-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 2rem);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c6-text-primary);
  }

  .blog-index-featured-wrap {
    display: grid;
  }

  .blog-index-featured-wrap[hidden],
  .blog-index-feed-wrap[hidden],
  .blog-index-state[hidden],
  .blog-index-feed .blog-post-card[hidden] {
    display: none !important;
  }

  .blog-index-featured {
    max-width: 100%;
  }

  .blog-index-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .blog-index-card-wrap {
    min-width: 0;
  }

  .blog-index-card {
    height: 100%;
  }

  .blog-index-card-featured :global(.blog-post-card-link) {
    padding: var(--space-8);
  }

  .blog-index-state {
    padding: var(--space-10) var(--space-8);
    border: 1px solid var(--c6-border);
    background: var(--c6-black-elevated);
    text-align: center;
  }

  .blog-index-state-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c6-text-primary);
    margin-bottom: var(--space-3);
  }

  .blog-index-state-copy {
    color: var(--c6-text-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  @media (max-width: 960px) {
    .blog-index-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .blog-index-hero {
      padding-top: calc(var(--space-24) + var(--space-8));
      padding-bottom: var(--space-8);
    }

    .blog-index-filters {
      top: 56px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-index-filter,
    .blog-index-card :global(.blog-post-card),
    .blog-index-card :global(.blog-post-card:hover) {
      transition: none;
    }
  }
</style>
